{% extends 'layouts/page.njk' %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% block content %}
<!-- Redirect users without JavaScript to the no-JS version -->
<noscript>
  <meta http-equiv="refresh" content="0; url=/airpollutant/nojs">
</noscript>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <form action='/addpollutants' method="post">
      
      <!-- Server-side validation errors -->
      {% if errors.list %}
        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                {% for error in errors.list %}
                <li>
                  <a href="{{ error.href }}">{{ error.text }}</a>
                </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <!-- Client-side duplicate error (for UX only) -->
      <div id="duplicate-error" class="govuk-error-summary" data-module="govuk-error-summary" hidden>
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#my-autocomplete">This pollutant has already been added</a></li>
            </ul>
          </div>
        </div>
      </div>

      <h1 class="govuk-heading-l">Add pollutant(s)</h1>
    
      <div class="govuk-form-group {% if errors.list and errors.list | length > 0 %}govuk-form-group--error{% endif %}">
        <fieldset class="govuk-fieldset" aria-describedby="mode-hint">
          <div id="mode-hint" class="govuk-hint">Select one option</div>

          <div class="govuk-radios" data-module="govuk-radios">
            <!-- MODE: specific -->
            <div class="govuk-radios__item">
              <input class="govuk-radios__input"
                     id="mode-specific"
                     name="pollutant-mode"
                     type="radio"
                     value="specific"
                     {% if selectedMode == "specific" %}checked{% endif %}
                     data-aria-controls="conditional-specific">
              <label class="govuk-label govuk-radios__label" for="mode-specific">
                Add pollutant(s)
              </label>
            </div>
            <div class="govuk-radios__conditional {% if selectedMode != 'specific' %}govuk-radios__conditional--hidden{% endif %}" id="conditional-specific">
              <div class="govuk-form-group" id="pollutant-form-group">
                <div class="govuk-hint">Add up to 10 pollutants</div>

                <!-- Progressive enhancement: Autocomplete for JS, select fallback for no-JS -->
                  <label id="pollutant-autocomplete-label" for="my-autocomplete" class="govuk-label govuk-visually-hidden">Add pollutant(s)</label>
                  <p id="pollutant-inline-error" class="govuk-error-message" hidden>
                    <span class="govuk-visually-hidden">Error:</span> <span id="pollutant-error-text"></span>
                  </p>
                  <div id="autocomplete-container-p" class="govuk-body" aria-labelledby="pollutant-autocomplete-label"></div>
                
              
                

                <div class="govuk-button-group govuk-!-margin-top-3">
                  {{ govukButton({
                    text: "Add pollutant",
                    classes: "govuk-button--secondary",
                    attributes: { id: "add-pollutant-button" }
                  }) }}
                </div>

                {% set list = selectedPollutants or [] %}
                {% set isSpecific = (selectedMode == 'specific') %}
                {% set hasSpecific = isSpecific and (list | length) > 0 %}

                <!-- Dynamic pollutants table -->
                <table
                  class="govuk-table govuk-!-margin-top-4"
                  id="pollutant-table"
                  {% if not hasSpecific %}hidden{% endif %}
                >
                  {% if hasSpecific %}
                    <caption class="govuk-table__caption govuk-table__caption--m">Added pollutants</caption>
                  {% endif %}
                  <tbody class="govuk-table__body">
                    {% if hasSpecific %}
                      {% for pollutant in list %}
                        <tr class="govuk-table__row">
                          <th scope="row" class="govuk-table__header">Pollutant {{ loop.index }}</th>
                          <td class="govuk-table__cell">{{ pollutant }}</td>
                          <td class="govuk-table__cell">
                            <a href="#" class="govuk-link remove-pollutant">Remove</a>
                          </td>
                        </tr>
                      {% endfor %}
                    {% endif %}
                  </tbody>
                </table>
              </div>
            </div>
            
            <!-- MODE: groups -->
            <div class="govuk-radios__item">
              <input class="govuk-radios__input"
                     id="mode-group"
                     name="pollutant-mode"
                     type="radio"
                     value="group"
                     {% if selectedMode == "group" %}checked{% endif %}
                     data-aria-controls="conditional-groups">
              <label class="govuk-label govuk-radios__label" for="mode-group">
                Add a group of pollutants
              </label>
            </div>

            <div class="govuk-radios__conditional {% if selectedMode != 'group' %}govuk-radios__conditional--hidden{% endif %}" id="conditional-groups">
              <div class="govuk-form-group">
                <fieldset class="govuk-fieldset" aria-describedby="pollutant-group-hint">
                  <legend class="govuk-fieldset__legend govuk-fieldset__legend--s"></legend>
                  <div id="pollutant-group-hint" class="govuk-hint">Select one option</div>

                  <div class="govuk-radios govuk-!-margin-top-3" data-module="govuk-radios">
                    <!-- Core / DAQI -->
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" 
                             id="pg-core" 
                             name="pollutant-group" 
                             type="radio" 
                             value="core" 
                             {% if selectedGroup == "core" %}checked{% endif %}
                             aria-describedby="pg-core-hint">
                      <label class="govuk-label govuk-radios__label" for="pg-core">Daily Air Quality Index (DAQI) pollutants</label>
                      <div id="pg-core-hint" class="govuk-hint govuk-radios__hint">
                        fine particulate matter (PM2.5), particulate matter (PM10), nitrogen dioxide (NO2), ozone (O3), sulphur dioxide (SO2)
                      </div>
                    </div>

                    <!-- Compliance -->
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" 
                             id="pg-compliance" 
                             name="pollutant-group" 
                             type="radio" 
                             value="compliance" 
                             {% if selectedGroup == "compliance" %}checked{% endif %}
                             aria-describedby="pg-compliance-hint">
                      <label class="govuk-label govuk-radios__label" for="pg-compliance">Pollutants in the Air Quality Standards Regulations 2010</label>
                      <div id="pg-compliance-hint" class="govuk-hint govuk-radios__hint">
                        fine particulate matter (PM2.5), particulate matter (PM10), nitrogen dioxide (NO2), ozone (O3), sulphur dioxide (SO2), nitric oxide (NO), nitrogen oxides as nitrogen dioxide (NOx as NO2), carbon monoxide (CO)  
                      </div>
                    </div>
                  </div>
                </fieldset>
              </div>
            </div>
          </div>
        </fieldset>
      </div>

      <!-- Hidden input to pass selected pollutants to the server -->
      <input type="hidden" id="selectedPollutantsInput" name="selectedPollutants" value="{% if selectedPollutants %}{{ selectedPollutants | dump | safe }}{% endif %}">

      {{ govukButton({
        text: "Continue",
        classes: "govuk-!-margin-top-3",
        attributes: { id: "continue-button" }
      }) }}
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Progressive enhancement: Only initialize if JavaScript is enabled
  
  // ---- Storage helpers + keys (for session persistence)
  const KEY_SELECTED = 'selectedPollutants';
  const KEY_GROUP = 'selectedPollutantGroup';  
  const KEY_SPECIFIC = 'selectedPollutants';
  const KEY_AUTOCOMPLETE_VALUE = 'pollutantAutocompleteValue';

  const readJSON = (k, fb = null) => {
    try { return JSON.parse(sessionStorage.getItem(k) || JSON.stringify(fb)); } catch { return fb; }
  };
  const writeJSON = (k, v) => sessionStorage.setItem(k, JSON.stringify(v || []));

  const getAutocompleteInput = () => document.getElementById('my-autocomplete');

  const setPersistedAutocompleteValue = (value) => {
    const v = (value ?? '').toString();
    if (v && v.trim()) {
      sessionStorage.setItem(KEY_AUTOCOMPLETE_VALUE, v);
    } else {
      sessionStorage.removeItem(KEY_AUTOCOMPLETE_VALUE);
    }
  };

  const restorePersistedAutocompleteValue = () => {
    const input = getAutocompleteInput();
    if (!input) return;
    const stored = sessionStorage.getItem(KEY_AUTOCOMPLETE_VALUE) || '';
    if (!stored) return;
    // Only restore if the box is empty (don’t overwrite user input)
    if (!input.value) input.value = stored;
  };

  // Capture the autocomplete input value on button mousedown — this fires
  // BEFORE mousedown causes blur on the input, which triggers accessible-autocomplete
  // to asynchronously clear input.value via setTimeout. By the time the 'click'
  // event fires the value is gone, causing the 2–3 click issue.
  let pendingButtonValue = '';

  // Pollutant list from server (fetched from API)
  const pollutantList = {{ pollutants | dump | safe }}.map(function(p) { return p.pollutant_value; });

  // Initialize autocomplete for pollutant selection
  function initializeAutocomplete() {
      const container = document.querySelector('#autocomplete-container-p');
      if (container && !container.querySelector('#my-autocomplete')) {
        if (window.accessibleAutocomplete) {

          // Restore any persisted value from sessionStorage (e.g., after validation error)
          const persistedValue = sessionStorage.getItem(KEY_AUTOCOMPLETE_VALUE) || '';

          // Debounce timer — delays showing suggestions by 3 seconds after the
          // user stops typing.
          let debounceTimer = null;

          window.accessibleAutocomplete({
            element: container,
            id: 'my-autocomplete',
            defaultValue: persistedValue,
            source: function(query, populateResults) {
              clearTimeout(debounceTimer);
              debounceTimer = setTimeout(function() {
                const q = (query || '').toLowerCase();
                const results = pollutantList.filter(function(p) {
                  return p.toLowerCase().indexOf(q) !== -1;
                });
                populateResults(results);
                // Show the menu after populating results
                setTimeout(() => {
                  const menu = getMenu();
                  if (menu) menu.style.removeProperty('display');
                }, 0);
              }, 1000);
            },
            minLength: 1,
            autoselect: false,
            confirmOnBlur: false,
            ariaLabelledBy: 'pollutant-autocomplete-label',
            onConfirm: function(confirmed) {
              if (confirmed) {
                setPersistedAutocompleteValue(confirmed);
                // Close the suggestion box after selection
                setTimeout(() => {
                  const menu = getMenu();
                  if (menu) menu.style.display = 'none';
                }, 50);
              }
            }
          });

          // Hide the dropdown menu during the delay to prevent "no results" message
          const getMenu = () => container.querySelector('.autocomplete__menu');
          const input = document.getElementById('my-autocomplete');
          if (input) {
            input.addEventListener('input', function() {
              const menu = getMenu();
              if (menu) menu.style.display = 'none';
            });
          }

          // Keep the current typed/selected value across a server-side validation reload
          setTimeout(function() {
            const inp = getAutocompleteInput();
            if (!inp) return;
            
            // Explicitly restore the persisted value (in case defaultValue was overridden)
            if (persistedValue && !inp.value) {
              inp.value = persistedValue;
            }
            
            // Add listeners to persist value as user types
            inp.addEventListener('input', function() {
              setPersistedAutocompleteValue(inp.value);
              clearClientErrors(); // Clear errors when user starts typing
            });
            inp.addEventListener('change', function() {
              setPersistedAutocompleteValue(inp.value);
            });
          }, 100);
        }
      }
  }

  // allowedPollutants reuses the API-fetched list — no separate hardcoded array needed
  const allowedPollutants = pollutantList;

  // Helper function to check if a pollutant is allowed
  const isAllowedPollutant = (value) => {
    const trimmedValue = (value || '').trim();
    return allowedPollutants.some(
      (pollutant) => pollutant.toLowerCase() === trimmedValue.toLowerCase()
    );
  };

  // Cache key elements
  const addButton = document.getElementById('add-pollutant-button');
  const continueButton = document.getElementById('continue-button');
  const table = document.getElementById('pollutant-table');
  const tableBody = table?.querySelector('tbody');

  // State for specific mode
  const addedPollutants = new Set(); // Track unique values (lowercased)

  // Helper to clear server-side errors
  function clearServerErrors() {
    // Hide server-side error summary
    const serverErrorSummary = document.querySelector('.govuk-error-summary:not([id])')
    if (serverErrorSummary) {
      serverErrorSummary.style.display = 'none'
    }
    
    // Remove error styling from all form groups
    const formGroups = document.querySelectorAll('.govuk-form-group--error')
    formGroups.forEach(fg => fg.classList.remove('govuk-form-group--error'))
  }

  // Helper to show client-side errors (both summary and inline)
  function showClientError(message, href = '#my-autocomplete') {
    clearServerErrors();
    
    // Show error summary
    const errorSummary = document.getElementById('duplicate-error');
    if (errorSummary) {
      const errorLink = errorSummary.querySelector('a');
      if (errorLink) {
        errorLink.textContent = message;
        errorLink.href = href;
      }
      errorSummary.hidden = false;
      errorSummary.style.display = 'block';
      errorSummary.focus();
      errorSummary.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    
    // Show inline error
    const inlineError = document.getElementById('pollutant-inline-error');
    const errorText = document.getElementById('pollutant-error-text');
    if (inlineError && errorText) {
      errorText.textContent = message;
      inlineError.hidden = false;
      inlineError.style.display = 'block';
    }
    
    // Add error styling to form group
    const formGroup = document.getElementById('pollutant-form-group');
    if (formGroup) {
      formGroup.classList.add('govuk-form-group--error');
    }
  }

  // Helper to clear client-side errors
  function clearClientErrors() {
    const errorSummary = document.getElementById('duplicate-error');
    if (errorSummary) {
      errorSummary.hidden = true;
      errorSummary.style.display = 'none';
    }
    
    const inlineError = document.getElementById('pollutant-inline-error');
    if (inlineError) {
      inlineError.hidden = true;
      inlineError.style.display = 'none';
    }
    
    const formGroup = document.getElementById('pollutant-form-group');
    if (formGroup) {
      formGroup.classList.remove('govuk-form-group--error');
    }
  }

  // Helper to update add button text
  function updateAddButtonText() {
    if (!addButton) return;
    const hasRows = !!(tableBody && tableBody.children && tableBody.children.length > 0)
    addButton.textContent = hasRows ? 'Add another pollutant' : 'Add pollutant';
  }

  // Helper to update row numbers after removal
  function updateRowNumbers() {
    if (!tableBody) return;
    const rows = Array.from(tableBody.querySelectorAll('tr'));
    rows.forEach((row, index) => {
      const headerCell = row.querySelector('th');
      if (headerCell) {
        headerCell.textContent = `Pollutant ${index + 1}`;
      }
    });
  }

  // Update hidden input with current pollutants for server submission
  function updateHiddenPollutantsInput(pollutants) {
    const hiddenInput = document.getElementById('selectedPollutantsInput');
    if (hiddenInput) {
      hiddenInput.value = JSON.stringify(pollutants || []);
    }
  }

  // Persist the current table rows
  function persistSpecificFromTable() {
    if (!tableBody) return;
    const rows = Array.from(tableBody.querySelectorAll('tr'));
    const list = rows.map(r => r.querySelector('td')?.textContent?.trim()).filter(Boolean);
    writeJSON(KEY_SPECIFIC, list);
    updateHiddenPollutantsInput(list);
  }

  // Core logic: validate and add a pollutant to the table.
  // Called from both the button click and the autocomplete onConfirm.
  function addPollutantToList(value) {
    value = (value || '').trim();
    const input = document.querySelector('#my-autocomplete');

    // Persist whatever the user has typed/selected, so it stays after server validation
    setPersistedAutocompleteValue(value);

    if (!value) {
      showClientError('Enter a pollutant');
      return;
    }

    if (!isAllowedPollutant(value)) {
      showClientError('Select a pollutant from the list');
      return;
    }

    const lowerValue = value.toLowerCase();

    if (addedPollutants.has(lowerValue)) {
      showClientError('This pollutant has already been added');
      return;
    }

    clearClientErrors();

    addedPollutants.add(lowerValue);

    if (table) {
      table.hidden = false;

      const row = document.createElement('tr');
      row.className = 'govuk-table__row';

      const headerCell = document.createElement('th');
      headerCell.scope = 'row';
      headerCell.className = 'govuk-table__header';
      headerCell.textContent = `Pollutant ${(tableBody?.children.length || 0) + 1}`;

      const valueCell = document.createElement('td');
      valueCell.className = 'govuk-table__cell';
      valueCell.textContent = value;

      const actionCell = document.createElement('td');
      actionCell.className = 'govuk-table__cell';

      const removeLink = document.createElement('a');
      removeLink.href = '#';
      removeLink.className = 'govuk-link remove-pollutant';
      removeLink.textContent = 'Remove';

      removeLink.addEventListener('click', function (e) {
        e.preventDefault();
        row.remove();
        addedPollutants.delete(lowerValue);
        updateRowNumbers();
        persistSpecificFromTable();
        if (tableBody?.children.length === 0) table.hidden = true;
        updateAddButtonText();
      });

      actionCell.appendChild(removeLink);
      row.appendChild(headerCell);
      row.appendChild(valueCell);
      row.appendChild(actionCell);
      if (tableBody) tableBody.appendChild(row);

      if (input) input.value = '';
      setPersistedAutocompleteValue('');
      persistSpecificFromTable();
      updateAddButtonText();
    }
  }

  // Add new pollutant via button (handles typed text not selected from dropdown)
  if (addButton) {
    addButton.addEventListener('mousedown', function (e) {
      const inp = document.querySelector('#my-autocomplete');
      if (inp) pendingButtonValue = inp.value.trim();
    });

    addButton.addEventListener('click', function (e) {
      e.preventDefault();
      const input = document.querySelector('#my-autocomplete');
      const value = (pendingButtonValue || (input && input.value) || '').trim();
      addPollutantToList(value);
      pendingButtonValue = '';
    });
  }

  // Handle continue button - validate on client side before submission
  if (continueButton) {
    continueButton.addEventListener('click', function (e) {
      e.preventDefault();
      
      const selectedMode = document.querySelector('input[name="pollutant-mode"]:checked')?.value;

      // CLIENT-SIDE VALIDATION
      // Check if mode is selected
      if (!selectedMode) {
        showClientError('Select an option before continuing', '#mode-specific');
        return;
      }

      // Validate specific mode - must have at least one pollutant in table
      if (selectedMode === 'specific') {
        const hasPollutants = tableBody && tableBody.children.length > 0;
        
        if (!hasPollutants) {
          showClientError('Enter a pollutant', '#my-autocomplete');
          return;
        }

        // Update hidden input with current pollutants
        let currentPollutants = [];
        const rows = tableBody.querySelectorAll('tr');
        rows.forEach(row => {
          const name = row.querySelector('td')?.textContent?.trim();
          if (name) currentPollutants.push(name);
        });
        updateHiddenPollutantsInput(currentPollutants);
        
        // Clear persisted autocomplete value since we have valid pollutants
        setPersistedAutocompleteValue('');
      }

      // Validate group mode - must have a group selected
      if (selectedMode === 'group') {
        const selectedGroup = document.querySelector('input[name="pollutant-group"]:checked')?.value;
        
        if (!selectedGroup) {
          showClientError(' Select a pollutant group', '#pg-core');
          return;
        }
      }

      // All validation passed - clear any client-side errors and submit
      clearClientErrors();
      
      const form = document.querySelector('form[action="/addpollutants"]');
      if (form) {
        form.submit();
      }
    });
  }

  // Initialize remove links for server-rendered pollutants
  document.querySelectorAll('.remove-pollutant').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const row = this.closest('tr');
      const pollutantName = row.querySelector('td')?.textContent?.trim();
      
      if (row && pollutantName) {
        row.remove();
        addedPollutants.delete(pollutantName.toLowerCase());
        updateRowNumbers();
        persistSpecificFromTable();

        if (tableBody?.children.length === 0) {
          table.hidden = true;
        }
        updateAddButtonText();
      }
    });
  });

  // Sync table visibility with selected mode and row existence
  function syncTableVisibility() {
    const selectedModeRadio = document.querySelector('input[name="pollutant-mode"]:checked')
    const isSpecific = selectedModeRadio && selectedModeRadio.value === 'specific'
    const hasRows = !!(tableBody && tableBody.children && tableBody.children.length > 0)
    if (table) {
      table.hidden = !(isSpecific && hasRows)
    }
  }

  // Initialize state from server-rendered pollutants
  if (tableBody) {
    const rows = tableBody.querySelectorAll('tr');
    rows.forEach(row => {
      const pollutantName = row.querySelector('td')?.textContent?.trim();
      if (pollutantName) {
        addedPollutants.add(pollutantName.toLowerCase());
      }
    });
  }
  updateAddButtonText();
  syncTableVisibility();

  // Handle radio button changes
  const modeRadios = document.querySelectorAll('input[name="pollutant-mode"]');
  modeRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      // Clear server-side errors when radio is selected
      clearServerErrors();

      if (this.value !== 'specific') {
        setPersistedAutocompleteValue('');
      }
      
      syncTableVisibility();
      if (this.value === 'specific' && this.checked) {
        setTimeout(() => { initializeAutocomplete(); }, 100);
      }
    });
  });

  // Initialize autocomplete if specific mode is already selected (e.g., on form errors)
  const selectedMode = document.querySelector('input[name="pollutant-mode"]:checked');
  if (selectedMode && selectedMode.value === 'specific') {
    // Small delay to ensure DOM is ready
    setTimeout(() => {
      initializeAutocomplete();
    }, 100);
  }
});
</script>

{% endblock %}
